// 1. ПОЛУЧИТЬ ТЕКУЩЕГО ПОЛЬЗОВАТЕЛЯ СЕССИИ
app.get("/api/user", (req, res) => {
  if (!currentSessionUser) {
    return res.status(401).json({ error: "Не авторизован" });
  }
  res.json(currentSessionUser);
});


// 2. РЕГИСТРАЦИЯ 
app.post("/api/register", (req, res) => {
  const { username, password } = req.body;

  if (!username || !password) {
    return res.status(400).json({ error: "Заполните все поля" });
  }

  // Проверяем, свободен ли никнейм
  const userExists = mockUsersDatabase.some(
    (u) => u.username.toLowerCase() === username.toLowerCase(),
  );
  if (userExists) {
    return res
      .status(400)
      .json({ error: "Пользователь с таким именем уже существует" });
  }

  const newUser = {
    id: mockUsersDatabase.length + 1,
    username: username.trim(),
    password: password,
    rank: "Junior Dev",
    xp: 0,
    solvedTasks: [],
    streak: 0,              // Инициализируем стрик
    lastActiveDate: null,   // Даты пока нет
    avatar: "🤖",           // Выдаем дефолтную аватарку робота-хакера
  };

  // Сохраняем в массив и делаем пользователя текущей сессией
  mockUsersDatabase.push(newUser);
  currentSessionUser = newUser;

  console.log(`[БД Заглушка] Зарегистрирован новый терминал: ${username}`);
  res.json(newUser);
});

// 3. АВТОРИЗАЦИЯ (ВХОД)
app.post("/api/login", (req, res) => {
  const { username, password } = req.body;

  const user = mockUsersDatabase.find(
    (u) => u.username === username && u.password === password,
  );

  if (!user) {
    return res
      .status(400)
      .json({ error: "Неверное имя пользователя или пароль" });
  }

  currentSessionUser = user;
  console.log(`[БД Заглушка] Вход в аккаунт: ${username}`);
  res.json(user);
});

// 4. ВЫХОД ИЗ АККАУНТА
app.post("/api/logout", (req, res) => {
  currentSessionUser = null;
  res.json({ success: true });
});

// 5. ПОЛУЧИТЬ УРОК ПО ID
app.get("/api/lessons/:id", (req, res) => {
  const lesson = lessonsData[req.params.id];
  if (!lesson) return res.status(404).json({ error: "Урок не найден" });
  res.json(lesson);
});

// 6. СОХРАНИТЬ ПРОГРЕСС И НАЧИСЛИТЬ XP И СТРИКИ
// === 6. СОХРАНИТЬ ПРОГРЕСС И НАЧИСЛИТЬ XP И СТРИКИ ===
app.post("/api/user/complete-lesson", (req, res) => {
  const { roomId, xpToAdd } = req.body;

  // 1. Проверяем авторизацию
  if (!currentSessionUser) {
    return res.status(401).json({ error: "Не авторизован" });
  }

  // 2. Находим пользователя в нашей фейк-БД
  const userInDb = mockUsersDatabase.find(
    (u) => u.id === currentSessionUser.id
  );

  if (!userInDb) {
    return res.status(404).json({ error: "Пользователь не найден" });
  }

  // 3. Безопасная проверка инициализации массива пройденных задач
  if (!userInDb.solvedTasks) {
    userInDb.solvedTasks = [];
  }

  // 4. Записываем ID комнаты в профиль, если его там еще нет
  if (roomId && !userInDb.solvedTasks.includes(roomId)) {
    userInDb.solvedTasks.push(roomId);
  }

  // 5. Начисление опыта
  userInDb.xp += xpToAdd || 250;

  // 6. Обновление рангов в сети
  if (userInDb.xp >= 500) userInDb.rank = "Elite Hacker";
  else if (userInDb.xp >= 250) userInDb.rank = "Senior Engineer";

  // 7. СТРОГОЕ ОГРАНИЧЕНИЕ СТРИКОВ: НЕ БОЛЕЕ +1 В ДЕНЬ
  const todayStr = new Date().toISOString().split('T')[0]; 

  if (!userInDb.lastActiveDate) {
    // Первый пройденный урок на аккаунте
    userInDb.streak = 1;
    userInDb.lastActiveDate = todayStr;
  } else {
    const lastDate = new Date(userInDb.lastActiveDate);
    const currentDate = new Date(todayStr);
    
    // Считаем чистую разницу в сутках
    const diffTime = currentDate - lastDate;
    const diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));

    if (diffDays === 1) {
      // Вернулся на следующий день
      userInDb.streak += 1;
      userInDb.lastActiveDate = todayStr;
    } else if (diffDays > 1) {
      // Был пропуск — стрик сгорает
      userInDb.streak = 1;
      userInDb.lastActiveDate = todayStr;
    }
    // Если diffDays === 0 (повторный урок сегодня) — стрик не меняется
  }

  // 8. Синхронизируем глобальную сессию
  currentSessionUser = userInDb;

  console.log(
    `[БД Заглушка] Комната ${roomId} пройдена кодером ${userInDb.username}. Пройденные: [${userInDb.solvedTasks.join(", ")}]. XP: ${userInDb.xp}, Стрик: ${userInDb.streak} дн.`
  );
  
  // 9. Отправляем финальный ответ на фронтенд (строго один раз в самом конце!)
  res.json(currentSessionUser);
});

// 7. ОБНОВЛЕНИЕ ДАННЫХ ПРОФИЛЯ (Имя, пароль, аватарка)
app.post("/api/user/update", (req, res) => {
  const { username, password, avatar } = req.body;

  if (!currentSessionUser) {
    return res.status(401).json({ error: "Не авторизован" });
  }

  const userInDb = mockUsersDatabase.find(
    (u) => u.id === currentSessionUser.id,
  );

  if (!userInDb) {
    return res.status(404).json({ error: "Пользователь не найден" });
  }

  if (username && username.toLowerCase() !== userInDb.username.toLowerCase()) {
    const nameExists = mockUsersDatabase.some(
      (u) => u.username.toLowerCase() === username.toLowerCase(),
    );
    if (nameExists) {
      return res
        .status(400)
        .json({ error: "Это имя кодера уже занято в сети" });
    }
  userInDb.username = username;
  }

  if (password) userInDb.password = password;
  if (avatar) userInDb.avatar = avatar;

  currentSessionUser = userInDb;

  console.log(
    `[БД Заглушка] Профиль обновлен для ID ${userInDb.id}: ${userInDb.username}`,
  );
  res.json(currentSessionUser);
}); // ← Add this closing brace if missing

// ЗАПУСК СЕРВЕРА
app.listen(5000, () => {
  console.log(
    "🚀 Автономный Бэкенд успешно запущен на http://localhost:5000",
  );
});
